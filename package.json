{
  "name": "picreader",
  "version": "1.0.0",
  "description": "Deep nested folder image viewer",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "package": "electron-builder",
    "postinstall": "node node_modules/electron/install.js"
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "type": "module",
  "build": {
    "appId": "com.picreader.app",
    "productName": "PicReader",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*"
    ],
    "win": {
      "target": "portable",
      "icon": "icon-256.png",
      "signAndEditExecutable": false
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "electronDownload": {
      "mirror": "https://npmmirror.com/mirrors/electron/"
    }
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@vitejs/plugin-vue": "^6.0.6",
    "electron": "^42.0.1",
    "electron-builder": "^26.8.1",
    "esbuild": "^0.28.0",
    "vite": "^8.0.10",
    "vite-plugin-electron": "^0.29.1",
    "vite-plugin-electron-renderer": "^0.14.7"
  },
  "dependencies": {
    "sharp": "^0.34.5",
    "vue-virtual-scroller": "^2.0.1"
  }
}
